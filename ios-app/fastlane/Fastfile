default_platform(:ios)

platform :ios do

  desc "Build a release-signed .ipa"
  lane :build_release do
    increment_build_number(
      build_number: latest_testflight_build_number + 1
    )

    build_app(
      workspace: "ARCodeCaptureApp.xcworkspace",
      scheme: "ARCodeCaptureApp",
      export_method: "app-store",
      output_directory: "build",
      output_name: "ARCodeCaptureApp.ipa"
    )
  end

  desc "Upload the latest build to TestFlight"
  lane :upload_testflight do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"]
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ARCodeCaptureApp.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false   # true فقط لو تبي توزيع خارجي بدون مراجعة يدوية إضافية
    )
  end

end
